@tailwind base;
@tailwind components;
@tailwind utilities;

:root {
  --bg: #ffffff;
  --surface: #ffffff;
  --muted: #f1f6fc;
  --border: #e1eaf4;
  --text: #0b1b30;
  --text-muted: #5b7align;
  --text-muted: #5b6b80;
  /* Brand blue — lay tu logo 睿扬旅游 / Ruiyang Travel */
  --accent: #1366c4;
  --accent-dark: #0c4a93;
  --accent-light: #3f9bf0;
}

* {
  border-color: var(--border);
}

html {
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
  scroll-behavior: smooth;
}

body {
  background: var(--bg);
  color: var(--text);
  font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto,
    "Helvetica Neue", Arial, "Noto Sans", "Liberation Sans", sans-serif,
    "Apple Color Emoji", "Segoe UI Emoji";
}

::selection {
  background: color-mix(in srgb, var(--accent) 18%, transparent);
}

.brand-gradient {
  background-image: linear-gradient(135deg, var(--accent-dark) 0%, var(--accent) 45%, var(--accent-light) 100%);
}
.text-brand-gradient {
  background-image: linear-gradient(135deg, var(--accent-dark) 0%, var(--accent-light) 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}
