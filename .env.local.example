# Copy file nay thanh .env.local roi dien gia tri tu Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# (Tuy chon) EmailJS — de nut "Gui gia qua email" o trang /requests gui TU DONG.
# Chua dien thi nut van dung duoc: se mo ung dung email cua admin voi noi dung soan san.
# Cach lay (free ~200 email/thang): https://www.emailjs.com
#   1) Email Services > Add New Service > Gmail -> lay Service ID
#   2) Email Templates > Create New Template:
#      - To Email:  {{to_email}}
#      - Subject:   {{subject}}
#      - Content:   {{message}}
#      -> lay Template ID
#   3) Account > General -> lay Public Key
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
